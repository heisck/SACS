{
  "name": "sacs-study-abroad",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade Next.js shell for a study abroad platform.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <27",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:load": "artillery run tests/load/smoke.yml",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check:dead-code": "knip",
    "analyze": "cross-env ANALYZE=true next build",
    "ci": "run-s lint typecheck test build"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.74",
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "1.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "10.60.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "@upstash/qstash": "2.11.1",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@upstash/workflow": "1.3.2",
    "@vercel/otel": "2.1.3",
    "ai": "7.0.18",
    "better-auth": "1.6.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "gl-matrix": "^3.4.4",
    "gsap": "^3.15.0",
    "jose": "6.2.3",
    "lenis": "^1.3.23",
    "lucide-react": "1.21.0",
    "matter-js": "^0.20.0",
    "motion": "^12.41.0",
    "nanoid": "5.1.16",
    "next": "16.2.9",
    "next-safe-action": "8.5.5",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-easy-crop": "^6.0.2",
    "react-email": "6.6.4",
    "react-hook-form": "7.80.0",
    "resend": "6.14.0",
    "server-only": "0.0.1",
    "tailwind-merge": "3.6.0",
    "three": "^0.184.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@hookform/resolvers": "5.4.0",
    "@next/bundle-analyzer": "16.2.9",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/matter-js": "^0.20.2",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "4.1.9",
    "artillery": "2.0.33",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.20.0",
    "lint-staged": "17.0.8",
    "msw": "2.14.6",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
