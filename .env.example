# App
APP_NAME="SACS Study Abroad"
APP_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
OTEL_SERVICE_NAME=sacs-study-abroad
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Database: Neon Postgres in production
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Cache and rate limiting: Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_PREFIX=sacs

# Background jobs: Upstash QStash / Workflow
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
UPSTASH_WORKFLOW_URL=

# Auth: Better Auth with Google OAuth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_DOMAINS=

# Email and newsletter
RESEND_API_KEY=
EMAIL_FROM="SACS <hello@example.com>"
EMAIL_REPLY_TO=
NEWSLETTER_PROVIDER=resend
NEWSLETTER_AUDIENCE_ID=

# SMS: Arkesel
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=
ARKESEL_BASE_URL=https://sms.arkesel.com/api/v2

# WhatsApp
WHATSAPP_PROVIDER=meta
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=

# Website bot / AI
OPENAI_API_KEY=
BOT_ESCALATION_EMAIL=

# Observability
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# E2E tests
PLAYWRIGHT_BASE_URL=
